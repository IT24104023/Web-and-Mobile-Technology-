{
  "version": 2,
  "buildCommand": "npm run build --workspace=frontend-web",
  "outputDirectory": "frontend-web/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://YOUR-ADAPTABLE-URL.adaptable.app/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://YOUR-ADAPTABLE-URL.adaptable.app/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
