{
  "version": 2,
  "buildCommand": "npm run build --workspace=frontend-web",
  "outputDirectory": "frontend-web/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://web-and-mobile-technology.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://web-and-mobile-technology.onrender.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
