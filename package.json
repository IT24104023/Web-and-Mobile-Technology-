{
  "name": "wmt-project-root",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "frontend-web",
    "backend"
  ],
  "scripts": {
    "build": "npm run build --workspace=frontend-web",
    "start": "npm start --workspace=backend",
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend-web\""
  },
  "dependencies": {
    "concurrently": "^8.2.2",

    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1"
  }
}
